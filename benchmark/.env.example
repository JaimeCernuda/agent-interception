# Config A: OpenAI-compatible endpoint (OpenRouter for dev, local vLLM for GPU runs)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-20b
LLM_API_KEY=sk-or-v1-...
LLM_PROVIDER_TAG=openrouter
# When the GPU is up, flip to:
#   LLM_BASE_URL=http://localhost:8000/v1
#   LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#   LLM_API_KEY=EMPTY
#   LLM_PROVIDER_TAG=vllm

# Configs B, C
ANTHROPIC_API_KEY=sk-
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Search backend (shared by all configs)
#   auto       - google_cse if keys present, else static
#   google_cse - paper-match (requires keys below)
#   ddg        - free, flaky
#   static     - use the urls[] field on each query in freshqa_20.json (deterministic)
SEARCH_BACKEND=static

# Optional - only used when SEARCH_BACKEND=google_cse or auto
GOOGLE_API_KEY=
GOOGLE_CX=
